<IfModule mod_rewrite.c>
  RewriteEngine On

  # Handle common legacy crawler paths early.
  RewriteRule ^favicon\.ico$ /favicon.png [R=301,L,NC]
  RewriteRule ^home(?:\.html)?$ / [R=301,L,NC]
  RewriteRule ^index\.php$ / [R=301,L,NC]
  RewriteRule ^assets/?$ / [R=301,L,NC]
  RewriteRule ^assets/images/?$ / [R=301,L,NC]

  # Force a single canonical host.
  RewriteCond %{HTTP_HOST} !^arslantech-eg\.com$ [NC]
  RewriteRule ^ https://arslantech-eg.com%{REQUEST_URI} [R=301,L]

  # Force HTTPS while avoiding loops behind reverse proxies.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://arslantech-eg.com%{REQUEST_URI} [R=301,L]

  # Canonical home URL.
  RewriteRule ^index(?:\.html)?$ / [R=301,L,NC]

  # Redirect direct .html requests to extensionless URLs.
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
  RewriteCond %{DOCUMENT_ROOT}/%1.html -f
  RewriteRule ^(.+)\.html$ /$1 [R=301,L]

  # Remove trailing slash for non-directory paths.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Serve .html files for extensionless routes.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_headers.c>
  # Apply index/follow to canonical public pages, including root path.
  SetEnvIfNoCase Request_URI "^$" is_public_page=1
  SetEnvIfNoCase Request_URI "^/?$" is_public_page=1
  SetEnvIfNoCase Request_URI "^/$" is_public_page=1
  SetEnvIfNoCase Request_URI "^/index(?:\.html?)?$" is_public_page=1
  SetEnvIfNoCase Request_URI "^/(about|academy|contact|services|products|projects|systems|web-design)/?$" is_public_page=1
  SetEnvIfNoCase Request_URI "^/(index|about|academy|contact|services|products|projects|systems|web-design)\.html$" is_public_page=1
  Header always unset X-Robots-Tag env=is_public_page
  Header always set X-Robots-Tag "index, follow" env=is_public_page

  # Prevent helper endpoints from being indexed.
  SetEnvIfNoCase Request_URI "^/(send_mail|csrf|test-email)\.php$" is_private_helper=1
  Header always unset X-Robots-Tag env=is_private_helper
  Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet" env=is_private_helper
</IfModule>